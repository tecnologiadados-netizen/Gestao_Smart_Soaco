# Fim de linha: LF no repositório e no checkout (evita avisos LF/CRLF no Windows).
* text=auto eol=lf

# Scripts nativos Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binários — não alterar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.docx binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
*.pem binary
*.crt binary
*.key binary

# Banco local (ajustes, coletas de preços, usuários) - SQLite
# Caminho relativo ao schema (backend/prisma/schema.prisma): use file:./dev.db
# DB_URL="file:./dev.db"
# Caminho absoluto (recomendado ao migrar de outro servidor):
# DB_URL="file:C:/Cursor - Projetos/Gestao_Smart/backend/prisma/dev.db"
DB_URL="file:./dev.db"

# Conexao Nomus (MySQL) - somente leitura. Senha: # = %23, @ = %40
NOMUS_DB_URL="mysql://usuario:senha@host:3306/weberp_soaco"

# Módulo Qualidade (SGQ) — consultas ERP reutilizam NOMUS_DB_URL acima
# SGQ_PORT=3001
# QUALIDADE_PRODUTOS_EMPRESA_ID=1

# Shop9 / SQL Server (DFC — leitura Financeiro_Contas)
SHOP9_DB_HOST=
SHOP9_DB_PORT=1433
SHOP9_DB_NAME=S9_Real
SHOP9_DB_USER=
SHOP9_DB_PASSWORD=
SHOP9_DB_ENCRYPT=true
SHOP9_DB_TRUST_CERT=true

# Produção: uma porta para API + SPA (após npm run build:frontend no backend). Ex.: 4000.
# Desenvolvimento na raiz: use "npm run dev" — o script força APP_PORT=4000 (Vite 5180 + 5173+5174+5051 fazem proxy).
APP_PORT=4000
NODE_ENV=production
JWT_SECRET=troque-isto-por-uma-chave-segura

# Domínio: DNS A @ e www → IP público. No MikroTik, NAT WAN TCP 80 e 443 → IP interno do servidor (ex. 10.80.1.187).
# Sem NAT na 80, Let's Encrypt (HTTP-01) falha com "Connection refused" no IP público.

# HTTPS no próprio Node: após deploy\request-acme-cert.ps1 (com NAT 80 OK), PEM em deploy/ssl/ ou:
# SSL_CERT_FILE=C:/caminho/fullchain.pem
# SSL_KEY_FILE=C:/caminho/privkey.pem
# SSL_PORT=443

# Redirecionar HTTP→HTTPS (só após TLS na 443 funcionar):
# FORCE_HTTPS_REDIRECT=true

# Atrás de nginx reverso: TRUST_PROXY=true
# TRUST_PROXY=true
# Cookies só em HTTPS:
# COOKIE_SECURE=true

# uazapiGO v2 – WhatsApp (https://docs.uazapi.com/)
UAZAPI_URL=https://seu-subdominio.uazapi.com
# Token admin (painel uazapi) — cria/recupera instância automaticamente se UAZAPI_TOKEN estiver vazio
UAZAPI_ADMIN_TOKEN=seu-token-admin
# Token da instância (opcional se ADMIN_TOKEN estiver configurado)

# Trava de segurança: envio REAL de e-mail e WhatsApp (crons e ações do sistema).
# Padrão DESABILITADO (dry-run: só loga, não envia). Em máquinas de desenvolvimento
# deixe vazio/false para NUNCA disparar mensagem real a clientes, mesmo usando banco
# e credenciais de produção. Somente o servidor de PRODUÇÃO deve definir =true.
NOTIFICACOES_ENVIO_HABILITADO=false

# E-mail (Gmail API OAuth) — credenciais salvas criptografadas no SQLite
# Gere a chave: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_SETTINGS_ENCRYPTION_KEY=
# Links nos templates de e-mail SGQ
# Dev: http://localhost:5180  |  Produção: https://gsmartsoaco.com.br (ou IP:4000)
APP_BASE_URL=https://gsmartsoaco.com.br
# Cron notificações SGQ (padrão: 08:00 diário)
# SGQ_EMAIL_CRON=0 8 * * *
# Catch-up de horários perdidos: se o backend reiniciou/estava fora no horário
# agendado, ao subir ele recupera horários vencidos hoje dentro desta janela
# (minutos). Padrão 180. Ex.: subiu 09:20 recupera o slot das 08:00.
# NOTIFICACAO_CATCHUP_TOLERANCIA_MIN=180
# DISPLAY_TIMEZONE=America/Sao_Paulo
UAZAPI_TOKEN=
UAZAPI_INSTANCE_NAME=gestor-pedidos
UAZAPI_WHATSAPP_NUMBER=

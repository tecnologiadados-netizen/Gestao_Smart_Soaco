model RhPontualidadePontoSnapshot {
  id             String   @id
  rowsJson       String   @default("[]") @map("rows")
  dateRangeStart String?  @map("date_range_start")
  dateRangeEnd   String?  @map("date_range_end")
  updatedAt      DateTime @default(now()) @map("updated_at")

  @@map("rh_pontualidade_ponto_snapshot")
}

model RhConfig {
  key       String    @id
  value     String?
  updatedAt DateTime? @default(now()) @map("updated_at")

  @@map("rh_config")
}

model RhReplaceSnapshots {
  id             String   @id @default(uuid())
  dataset        String
  actor          String?
  action         String   @default("replace")
  rowCountBefore Int      @default(0) @map("row_count_before")
  snapshotJson   String   @map("snapshot")
  metaJson       String   @default("{}") @map("meta")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("rh_replace_snapshots")
}

model RhOrganicoLogSancaoFingerprint {
  fingerprint         String   @id
  organicoComentarioId String  @map("organico_comentario_id")
  createdAt           DateTime @default(now()) @map("created_at")

  organicoComentario RhOrganicoComentarios @relation(fields: [organicoComentarioId], references: [id], onDelete: Cascade)

  @@map("rh_organico_log_sancao_fingerprint")
}

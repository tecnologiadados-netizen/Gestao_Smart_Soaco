// =============================================================================
// Módulo RH — models para append em schema.prisma (SQLite)
// Conversões: uuid→String @default(uuid()), jsonb→String, timestamptz→DateTime,
// numeric→Float, date→DateTime (quando aplicável).
// =============================================================================
//
// NOTA (schema.prisma — model GrupoUsuario): adicionar relação inversa:
//   rhGrupoPermissao RhGrupoPermissao?
//
// =============================================================================

// Permissões granulares RH (RhGroupPermissions v2) por grupo do Gestor.
model RhGrupoPermissao {
  id          String   @id @default(uuid())
  grupoId     Int      @unique @map("grupo_id")
  permissions String   @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  grupo GrupoUsuario @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@map("rh_grupo_permissao")
}

model RhOrganico {
  id           String    @id @default(uuid())
  matricula    String
  nome         String
  cargo        String
  setor        String
  area         String?
  lider        String?
  dataAdmissao DateTime? @map("data_admissao")
  status       String    @default("Ativo")
  valuesJson   String    @default("[]") @map("values_json")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("rh_organico")
}

model RhFaltasAtestados {
  id               String    @id @default(uuid())
  data             DateTime
  mesFalta         String?   @map("mes_falta")
  matricula        String
  nomeFuncionario  String    @map("nome_funcionario")
  endereco         String?
  area             String?
  setor            String?
  lider            String?
  periodo          String?
  qntd             String?
  diasTurno        String?   @map("dias_turno")
  tipo             String?
  cid              String?
  localAtendimento String?   @map("local_atendimento")
  medicoResponsavel String?  @map("medico_responsavel")
  observacoes      String?
  aprovado         String?
  reprovado        String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("rh_faltas_atestados")
}

model RhSancoesDisciplinares {
  id              String    @id @default(uuid())
  matricula       String
  nomeFuncionario String    @map("nome_funcionario")
  tipo            String?
  dataAplicacao   DateTime  @map("data_aplicacao")
  mes             String?
  ano             String?
  observacoes     String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("rh_sancoes_disciplinares")
}

model RhFaltasCadPeriodos {
  id        String   @id @default(uuid())
  ordem     Int

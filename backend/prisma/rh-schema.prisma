  @@map("rh_faltas_cad_periodos")
}

model RhFaltasCadTipos {
  id                      String   @id @default(uuid())
  ordem                   Int
  valor                   String
  contabilizaIndicadores  Boolean  @default(true) @map("contabiliza_indicadores")

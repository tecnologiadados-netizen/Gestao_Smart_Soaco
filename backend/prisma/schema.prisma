/// Snapshot gravado na tela Sequenciamento carradas (estado do Gerenciador no momento do Gravar).
model SequenciamentoCarradasSnapshot {
  id           Int      @id @default(autoincrement())
  /// Código legível do snapshot (ex.: SC-20250610-001).
  cod          String   @unique
  usuarioLogin String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
  carradaCount Int      @default(0)
  /// Fluxo: 'rascunho' (editável, autosave) -> 'concluido' (somente leitura).
  /// Default 'concluido' para compatibilidade com snapshots antigos; novos nascem 'rascunho'.
  status       String   @default("concluido")
  /// JSON v1: carradas agregadas + linhas completas do Gerenciador.
  payload      String

  @@index([createdAt])
  @@map("sequenciamento_carradas_snapshot")
}

/// Ticket de suporte interno (abertura por usuário comum e gestão pelo master).
model SupportTicket {
  id                 Int      @id @default(autoincrement())
  ticketNumber       String   @unique
  ownerLogin         String
  ownerNome          String?
  tipo               String
  titulo             String
  descricao          String
  categoria          String?
  prioridade         String   @default("media")
  status             String   @default("aberto")
  customFieldsJson   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lastStatusChangeAt DateTime @default(now())
  lastStatusChangeBy String?
  mensagens          SupportTicketMessage[]
  anexos             SupportTicketAttachment[]
  historicoStatus    SupportTicketStatusHistory[]
  notificacoes       SupportTicketNotification[]
  reads              SupportTicketRead[]

  @@index([ownerLogin])
  @@index([status])
  @@index([prioridade])
  @@index([createdAt])
  @@map("support_ticket")
}

/// Estado de leitura individual do chamado por usuário (lido/não lido por master).
model SupportTicketRead {
  ticketId  Int
  userLogin String
  readAt    DateTime? // quando preenchido = lido; null = não lido (master pode reverter)
  updatedAt DateTime  @updatedAt
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([ticketId, userLogin])
  @@index([userLogin])
  @@map("support_ticket_read")
}

/// Mensagens no histórico do chamado (usuário comum e master).
model SupportTicketMessage {
  id          Int      @id @default(autoincrement())
  ticketId    Int
  authorLogin String
  authorNome  String?
  authorType  String   // usuario | master
  mensagem    String
  createdAt   DateTime @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  anexos      SupportTicketAttachment[]

  @@index([ticketId])
  @@index([createdAt])
  @@map("support_ticket_message")
}

/// Anexos enviados no chamado (abertura e respostas).
model SupportTicketAttachment {
  id           Int      @id @default(autoincrement())
  ticketId     Int
  messageId    Int?
  fileName     String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  createdAt    DateTime @default(now())
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message      SupportTicketMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([messageId])
  @@map("support_ticket_attachment")
}

/// Histórico de mudanças de status com auditoria.
model SupportTicketStatusHistory {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  fromStatus String?
  toStatus   String
  changedBy  String
  changedAt  DateTime @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([changedAt])
  @@map("support_ticket_status_history")
}

/// Notificação interna (estrutura pronta para integração de alertas no frontend).
model SupportTicketNotification {

  pdfAssinadoNome         String?   @map("pdf_assinado_nome")
  pdfAssinadoStoragePath  String?   @map("pdf_assinado_storage_path")
  pdfAssinadoMimeType     String?   @map("pdf_assinado_mime_type")
  pdfAssinadoEm           DateTime? @map("pdf_assinado_em")
  pdfAssinadoPorLogin     String?   @map("pdf_assinado_por_login")
  encerrada            Boolean   @default(false)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  eventos              CrmCreditoPendenciaEvento[]

  @@index([clienteChave])
  @@index([encerrada, alertaEm])
  @@index([acao])
  @@map("crm_credito_pendencia")
}


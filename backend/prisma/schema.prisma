  emailAcaoEnviadoEm   DateTime? @map("email_acao_enviado_em")
  /// E-mail de SLA (prazo sem ação) já enviado ao gestor para esta pendência.
  emailSlaEnviadoEm    DateTime? @map("email_sla_enviado_em")

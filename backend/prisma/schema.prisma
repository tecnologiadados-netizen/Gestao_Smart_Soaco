  fromName               String    @map("from_name")
  clientId               String    @map("client_id")
  clientSecretEncrypted  String    @map("client_secret_encrypted")
  refreshTokenEncrypted  String    @map("refresh_token_encrypted")
  lastTestedAt           DateTime? @map("last_tested_at")
  lastError              String?
  credentialBlockedAt    DateTime? @map("credential_blocked_at")
  credentialBlockCode    String?   @map("credential_block_code")
  credentialBlockSummary String?   @map("credential_block_summary")
  createdAt              DateTime  @default(now()) @map("created_at")

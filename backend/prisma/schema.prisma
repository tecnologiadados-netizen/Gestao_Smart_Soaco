  uid       String   @unique @default(cuid())
  sigla     String
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sigla])
  @@map("sgq_setor")
}

model SgqTipoDocumento {
  id        Int      @id @default(autoincrement())
  uid       String   @unique @default(cuid())
  sigla     String   @unique
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sgq_tipo_documento")
}

model SgqOpcaoLista {
  id        Int      @id @default(autoincrement())
  chave     String
  valor     String
  sortOrder Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([chave, valor])
  @@index([chave])
  @@map("sgq_opcao_lista")
}

model SgqDocumento {
  id                  Int      @id @default(autoincrement())
  uid                 String   @unique @default(cuid())
  codigo              String   @unique
  titulo              String
  origem              String
  status              String
  tipoUid             String
  setorUid            String
  versaoAtual         String
  localizacao         String?
  permissoesJson      String?
  publicacaoJson      String?
  validadeJson        String?
  externoRegistroJson String?
  criadoPorLogin      String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  versoes      SgqDocumentoVersao[]
  revalidacoes SgqDocumentoRevalidacao[]
  alertas      SgqDocumentoAlerta[]

  @@index([status])
  @@index([tipoUid])
  @@index([setorUid])
  @@map("sgq_documento")
}

model SgqDocumentoVersao {
  id                       Int      @id @default(autoincrement())
  uid                      String   @unique @default(cuid())
  documentoId              Int
  versao                   String
  elaboradorLogin          String?
  consensoLogin            String?
  revisorLogin             String?
  aprovadorLogin           String?
  prazosJson               String?
  dataElaboracao           String?
  dataRevisao              String?
  dataAprovacao            String?
  observacoes              String?
  justificativaRevisao     String?
  alteracoesRevisao        String?
  observacoesElaboracao    String?
  observacoesConsenso      String?
  observacoesAprovacao     String?
  movimentacoesJson        String?
  requerSubstituicaoConsenso Boolean @default(false)
  arquivoNome              String?
  arquivoStoragePath       String?
  arquivoMimeType          String?
  arquivoAtualizadoEm      String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  documento SgqDocumento @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@unique([documentoId, versao])
  @@index([documentoId])
  @@map("sgq_documento_versao")
}

model SgqDocumentoRevalidacao {
  id                 Int      @id @default(autoincrement())
  uid                String   @unique @default(cuid())
  documentoId        Int
  data               String
  observacoes        String
  evidenciaNome      String?
  evidenciaStoragePath String?
  novaDataValidade   String
  usuarioLogin       String
  createdAt          DateTime @default(now())

  documento SgqDocumento @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@index([documentoId])
  @@map("sgq_documento_revalidacao")
}

model SgqDocumentoAlerta {
  id          Int      @id @default(autoincrement())
  uid         String   @unique @default(cuid())
  documentoId Int
  marcoDias   Int
  severidade  String
  mensagem    String
  lida        Boolean  @default(false)
  createdAt   DateTime @default(now())

  documento SgqDocumento @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@index([documentoId])
  @@map("sgq_documento_alerta")
}

model SgqRegistro {

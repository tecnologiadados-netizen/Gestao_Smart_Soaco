# Copie para .env.development.local (não commitar).
#
# Acesso pelo domínio na porta 80 (MikroTik NAT 80 -> 5173 no PC):
# o Vite em dev tenta WebSocket de HMR na porta 5173; de fora só a 80 costuma estar aberta.
# Opção A — desativar HMR (recomendado para testar pelo nome sem :5173):
# VITE_DISABLE_HMR=true
# VITE_DEV_ORIGIN=http://gsmartsoaco.com.br
#
# Opção B — manter HMR usando a mesma porta pública:
# VITE_HMR_CLIENT_PORT=80
# VITE_DEV_ORIGIN=http://gsmartsoaco.com.br
